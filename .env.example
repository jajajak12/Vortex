# Vortex Trading Agent — Environment Variables
# Copy file ini ke .env, isi dengan nilai asli, JANGAN commit .env ke git.
#
# Setup:
#   cp .env.example .env
#   nano .env          # isi nilai asli
#   source .env        # load ke shell sebelum jalankan scanner

# WAJIB — scanner tidak bisa jalan tanpa ini
VORTEX_BINANCE_KEY=your_binance_api_key_here
VORTEX_BINANCE_SECRET=your_binance_api_secret_here
VORTEX_TELEGRAM_TOKEN=your_telegram_bot_token_here

# Opsional — default sudah diset di config.py
VORTEX_TELEGRAM_CHAT_ID=your_telegram_chat_id_here
VORTEX_MINIMAX_KEY=your_minimax_api_key_here
VORTEX_GITHUB_PAT=your_github_pat_here
